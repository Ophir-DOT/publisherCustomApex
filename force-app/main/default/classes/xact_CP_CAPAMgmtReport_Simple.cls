/**
 * @description       : Simple CAPA Management Report for Content Publisher. Generates HTML blocks
 *                      for all open CAPAs using the standard black-header card style matching
 *                      the Related Findings pattern. The recordId parameter is intentionally
 *                      ignored — this class queries all CAPAs org-wide.
 * @author            : Ophir Peleg
 * @last modified on  : 04-20-2026
 * @last modified by  : Ophir Peleg
 **/
global with sharing class xact_CP_CAPAMgmtReport_Simple implements CompSuite.CP_DynamicContentGenerator {

    private static final String FONT_FAMILY = '\'Arial Unicode MS\', \'Aptos\', Arial, Helvetica, sans-serif';
    private static final String FONT_SIZE = '10pt';
    private static final String SECTION_HEADER_STYLE = 'background-color:#000000; color:white; font-weight:bold; padding:4px 8px; font-size:10pt;';
    private static final String CONTENT_CELL_STYLE = 'padding:4px; border:1px solid black; vertical-align:top; display:table-cell; width:100%;';

    // ============================================
    // Interface Methods
    // ============================================

    public String getJSON(Id recordId, String input) {
        return null;
    }

    public String getHTML(Id recordId, String input) {
        return buildReport();
    }

    // ============================================
    // Report Building
    // ============================================

    private String buildReport() {
        List<CompSuite__CAPA__c> capas = queryOpenCAPAs();

        String html = '<div style="font-family: ' + FONT_FAMILY + '; font-size: ' + FONT_SIZE + '; align-content:center; width:100%;">';

        // Report header
        html += buildReportHeader();

        // Filter info
        html += '<div style="font-size:8pt; color:#666666; margin:8px 0 14px 0;">';
        html += '<b>Filtered By</b><br/>';
        html += 'Show: All CAPAs<br/>';
        html += 'State: State Name does not contain Completed, Cancelled';
        html += '</div>';

        if (capas.isEmpty()) {
            html += '<p style="font-size:10pt; color:#666666; padding:20px; text-align:center;">No open CAPAs found</p>';
        } else {
            Boolean isFirst = true;
            for (CompSuite__CAPA__c capa : capas) {
                if (!isFirst) {
                    html += '<br style="page-break-before: always">';
                }
                isFirst = false;
                html += buildCAPABlock(capa);
            }
        }

        html += '</div>';
        return html;
    }

    private String buildReportHeader() {
        TimeZone tz = UserInfo.getTimeZone();
        DateTime now = DateTime.now();
        Integer offsetMs = tz.getOffset(now);
        DateTime localDt = now.addSeconds(offsetMs / 1000);
        String formattedDate = localDt.formatGmt('yyyy-MM-dd HH:mm:ss') + ' ' + tz.getID();
        String userName = UserInfo.getName();

        String html = '';
        html += '<p style="font-size:14pt; font-weight:bold; margin:0 0 4px 0;">CAPA Management Report</p>';
        html += '<p style="font-size:9pt; color:#555555; margin:0 0 2px 0;">As of ' + formattedDate + ' &bull; Generated by ' + safeString(userName) + '</p>';
        return html;
    }

    // ============================================
    // CAPA Block
    // ============================================

    private String buildCAPABlock(CompSuite__CAPA__c capa) {
        String stateName = (capa.CompSuite__State__r != null) ? capa.CompSuite__State__r.Name : '';
        String ownerName = (capa.Owner != null) ? capa.Owner.Name : '';

        String html = '';

        // Black header bar
        html += '<div style="width:100%; display:table; table-layout:fixed;">';
        html += '<div style="border:1px solid black; margin-bottom:10px; page-break-inside:avoid;">';
        html += '<div style="' + SECTION_HEADER_STYLE + '">CAPA: ' + safeString(capa.CAPA_Number__c) + '</div>';
        html += '</div>';
        html += '</div>';

        // Content block with fields
        html += '<div style="width:100%; display:table; table-layout:fixed;">';
        html += '<div style="' + CONTENT_CELL_STYLE + '">';
        html += '<div style="padding:10px 6px 6px 10px;">';
        html += '<p style="margin:2px 0;"><b>CAPA Name: </b>' + safeString(capa.Name) + '</p>';
        html += '<p style="margin:2px 0;"><b>Owner Name: </b>' + safeString(ownerName) + '</p>';
        html += '<p style="margin:2px 0;"><b>Action Plan Description: </b>' + safeString(capa.CompSuite__Action_Plan_Description__c) + '</p>';
        // html += '<p style="margin:2px 0;"><b>CAPA Summary: </b>' + safeString(...) + '</p>';              // TBD
        html += '<p style="margin:2px 0;"><b>Planned Due Date: </b>' + formatDate(capa.CompSuite__Due_Date__c) + '</p>';
        html += '<p style="margin:2px 0;"><b>Completion Date: </b>' + formatDate(capa.Completion_Date__c) + '</p>';
        html += '<p style="margin:2px 0;"><b>State: </b>' + safeString(stateName) + '</p>';
        // html += '<p style="margin:2px 0;"><b>Effective Check Required: </b>' + safeString(...) + '</p>';  // TBD
        // html += '<p style="margin:2px 0;"><b>CAPA Source: </b>' + safeString(...) + '</p>';               // TBD
        html += '</div>';
        html += '</div>';
        html += '</div>';
        html += '<br/>';

        return html;
    }

    // ============================================
    // Query Methods
    // ============================================

    private List<CompSuite__CAPA__c> queryOpenCAPAs() {
        return [
            SELECT Id, Name, CAPA_Number__c,
                   Owner.Name,
                   CompSuite__Action_Plan_Description__c,
                   CompSuite__Due_Date__c,
                   Completion_Date__c,
                   CompSuite__State__r.Name
            FROM CompSuite__CAPA__c
            WHERE CompSuite__State__r.Name = null
               OR ((NOT CompSuite__State__r.Name LIKE '%Completed%')
                   AND (NOT CompSuite__State__r.Name LIKE '%Cancelled%'))
            WITH SECURITY_ENFORCED
            ORDER BY CAPA_Number__c ASC
        ];
    }

    // ============================================
    // Utility Methods
    // ============================================

    @TestVisible
    private String safeString(String value) {
        return String.isBlank(value) ? '' : value.escapeHtml4();
    }

    @TestVisible
    private String formatDate(Date d) {
        if (d == null) {
            return '';
        }
        DateTime dt = DateTime.newInstance(d.year(), d.month(), d.day());
        return dt.format('yyyy-MM-dd');
    }
}
