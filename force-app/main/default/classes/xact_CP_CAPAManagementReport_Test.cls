@isTest
private class xact_CP_CAPAManagementReport_Test {

    @isTest
    static void testGetJSON_returnsNull() {
        Test.startTest();
        xact_CP_CAPAManagementReport gen = new xact_CP_CAPAManagementReport();
        String json = gen.getJSON(null, null);
        Test.stopTest();

        System.assertEquals(null, json, 'getJSON should return null');
    }

    @isTest
    static void testGetHTML_noCAPAs() {
        Test.startTest();
        xact_CP_CAPAManagementReport gen = new xact_CP_CAPAManagementReport();
        String html = gen.getHTML(null, null);
        Test.stopTest();

        System.assert(html.contains('No open CAPAs found'), 'Should show empty state message');
        System.assert(html.contains('CAPA Management Report'), 'Should contain report title');
    }

    @isTest
    static void testGetHTML_withCAPAs() {
        CompSuite__CAPA__c capa = new CompSuite__CAPA__c();
        insert capa;

        Test.startTest();
        xact_CP_CAPAManagementReport gen = new xact_CP_CAPAManagementReport();
        String html = gen.getHTML(null, null);
        Test.stopTest();

        System.assert(html.contains('CAPA Management Report'), 'Should contain report title');
        System.assert(html.contains('CAPA Records'), 'Should contain section heading');
        System.assert(html.contains('Owner'), 'Should contain Owner field label');
    }

    @isTest
    static void testGetHTML_reportHeader() {
        Test.startTest();
        xact_CP_CAPAManagementReport gen = new xact_CP_CAPAManagementReport();
        String html = gen.getHTML(null, null);
        Test.stopTest();

        System.assert(html.contains('CAPA Management Report'), 'Should contain report title');
        System.assert(html.contains('Dot Compliance'), 'Should contain brand name');
        System.assert(html.contains('Generated By'), 'Should contain generated by label');
        System.assert(html.contains('Filters applied'), 'Should contain filter section');
        System.assert(html.contains('Completed'), 'Should show state exclusion');
        System.assert(html.contains('Cancelled'), 'Should show state exclusion');
    }

    @isTest
    static void testGetHTML_summaryKPIs() {
        CompSuite__CAPA__c capa = new CompSuite__CAPA__c();
        insert capa;

        Test.startTest();
        xact_CP_CAPAManagementReport gen = new xact_CP_CAPAManagementReport();
        String html = gen.getHTML(null, null);
        Test.stopTest();

        System.assert(html.contains('Total Records'), 'Should contain Total Records KPI');
        System.assert(html.contains('Open CAPAs'), 'Should contain Open CAPAs KPI');
        System.assert(html.contains('Due This Week'), 'Should contain Due This Week KPI');
        System.assert(html.contains('Overdue'), 'Should contain Overdue KPI');
    }

    @isTest
    static void testGetHTML_timeline() {
        CompSuite__CAPA__c capa = new CompSuite__CAPA__c(
            CompSuite__Due_Date__c = Date.today()
        );
        insert capa;

        Test.startTest();
        xact_CP_CAPAManagementReport gen = new xact_CP_CAPAManagementReport();
        String html = gen.getHTML(null, null);
        Test.stopTest();

        System.assert(html.contains('Current State'), 'Should contain timeline state node');
        System.assert(html.contains('Planned Due'), 'Should contain timeline due node');
        System.assert(html.contains('Not yet completed'), 'Should show pending completion');
    }

    @isTest
    static void testGetHTML_footer() {
        Test.startTest();
        xact_CP_CAPAManagementReport gen = new xact_CP_CAPAManagementReport();
        String html = gen.getHTML(null, null);
        Test.stopTest();

        System.assert(html.contains('Dot Compliance eQMS'), 'Should contain footer branding');
        System.assert(html.contains('Confidential'), 'Should contain confidential notice');
    }

    @isTest
    static void testGetHTML_withCAPAPlan() {
        CompSuite__CAPA_Plan__c plan = new CompSuite__CAPA_Plan__c();
        insert plan;
        CompSuite__CAPA__c capa = new CompSuite__CAPA__c(CAPA_Plan__c = plan.Id);
        insert capa;

        Test.startTest();
        xact_CP_CAPAManagementReport gen = new xact_CP_CAPAManagementReport();
        String html = gen.getHTML(null, null);
        Test.stopTest();

        System.assert(html.contains('CAPA Records'), 'Should render CAPA section');
    }

    @isTest
    static void testSafeString_handlesNull() {
        xact_CP_CAPAManagementReport gen = new xact_CP_CAPAManagementReport();

        System.assertEquals('', gen.safeString(null), 'Null should return empty string');
        System.assertEquals('', gen.safeString(''), 'Empty should return empty string');
        System.assertEquals('', gen.safeString('   '), 'Blank should return empty string');
        System.assertEquals('Test', gen.safeString('Test'), 'Normal string should be returned');
        System.assertEquals('&lt;b&gt;', gen.safeString('<b>'), 'HTML should be escaped');
    }

    @isTest
    static void testFormatDate_handlesNull() {
        xact_CP_CAPAManagementReport gen = new xact_CP_CAPAManagementReport();

        System.assertEquals('', gen.formatDate(null), 'Null date should return empty string');
        String result = gen.formatDate(Date.newInstance(2026, 3, 15));
        System.assert(result.contains('2026'), 'Should contain the year');
    }
}
