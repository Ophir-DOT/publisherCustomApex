/**
 * @description       : CAPA Plan Report for Content Publisher. Generates HTML blocks for all
 *                      open CAPA Plans with their related CAPA records nested underneath.
 *                      Uses the standard black-header card style. The recordId parameter is
 *                      intentionally ignored — this class queries all open CAPA Plans org-wide.
 * @author            : Ophir Peleg
 * @last modified on  : 04-21-2026
 * @last modified by  : Claude
 **/
global with sharing class xact_CP_CAPAPlanReport implements CompSuite.CP_DynamicContentGenerator {

    private static final String FONT_FAMILY = '\'Arial Unicode MS\', \'Aptos\', Arial, Helvetica, sans-serif';
    private static final String FONT_SIZE = '10pt';
    private static final String SECTION_HEADER_STYLE = 'background-color:#000000; color:white; font-weight:bold; padding:4px 8px; font-size:10pt;';
    private static final String SUBSECTION_HEADER_STYLE = 'background-color:#000000; color:white; font-weight:bold; padding:4px 8px; font-size:9pt;';
    private static final String CONTENT_CELL_STYLE = 'padding:4px; border:1px solid black; vertical-align:top; display:table-cell; width:100%;';

    // ============================================
    // Interface Methods
    // ============================================

    public String getJSON(Id recordId, String input) {
        return null;
    }

    public String getHTML(Id recordId, String input) {
        return buildReport();
    }

    // ============================================
    // Report Building
    // ============================================

    private String buildReport() {
        // Query open CAPA Plans
        List<CompSuite__CAPA_Plan__c> plans = queryOpenCAPAPlans();

        if (plans.isEmpty()) {
            return buildWrapper('<p style="font-size:10pt; color:#666666; padding:20px; text-align:center;">No open CAPA Plans found</p>');
        }

        // Collect plan IDs and query all related CAPAs in bulk
        Set<Id> planIds = new Set<Id>();
        for (CompSuite__CAPA_Plan__c plan : plans) {
            planIds.add(plan.Id);
        }
        Map<Id, List<CompSuite__CAPA__c>> planToCAPAs = queryCAPAsByPlan(planIds);

        // Build output
        String html = '';
        html += buildReportHeader(plans.size());

        Boolean isFirst = true;
        for (CompSuite__CAPA_Plan__c plan : plans) {
            if (!isFirst) {
                html += '<br style="page-break-before: always">';
            }
            isFirst = false;

            List<CompSuite__CAPA__c> relatedCAPAs = planToCAPAs.containsKey(plan.Id)
                ? planToCAPAs.get(plan.Id)
                : new List<CompSuite__CAPA__c>();

            html += buildPlanBlock(plan, relatedCAPAs);
        }

        return buildWrapper(html);
    }

    private String buildWrapper(String content) {
        return '<div style="font-family: ' + FONT_FAMILY + '; font-size: ' + FONT_SIZE + '; align-content:center; width:100%;">'
             + content
             + '</div>';
    }

    private String buildReportHeader(Integer planCount) {
        TimeZone tz = UserInfo.getTimeZone();
        DateTime now = DateTime.now();
        Integer offsetMs = tz.getOffset(now);
        DateTime localDt = now.addSeconds(offsetMs / 1000);
        String formattedDate = localDt.formatGmt('yyyy-MM-dd HH:mm:ss') + ' ' + tz.getID();
        String userName = UserInfo.getName();

        String html = '';
        html += '<p style="font-size:14pt; font-weight:bold; margin:0 0 4px 0;">CAPA Plan Report</p>';
        html += '<p style="font-size:9pt; color:#555555; margin:0 0 2px 0;">As of ' + formattedDate + ' &bull; Generated by ' + safeString(userName) + '</p>';

        html += '<div style="font-size:8pt; color:#666666; margin:8px 0 14px 0;">';
        html += '<b>Filtered By</b><br/>';
        html += 'Show: All CAPA Plans<br/>';
        html += 'State: State Name does not contain Completed, Cancelled<br/>';
        html += 'Total Plans: ' + String.valueOf(planCount);
        html += '</div>';

        return html;
    }

    // ============================================
    // CAPA Plan Block (with nested CAPAs)
    // ============================================

    private String buildPlanBlock(CompSuite__CAPA_Plan__c plan, List<CompSuite__CAPA__c> relatedCAPAs) {
        String planState = (plan.CompSuite__State__r != null) ? plan.CompSuite__State__r.Name : '';

        String html = '';

        // Plan header bar
        html += '<div style="width:100%; display:table; table-layout:fixed;">';
        html += '<div style="border:1px solid black; margin-bottom:10px; page-break-inside:avoid;">';
        html += '<div style="' + SECTION_HEADER_STYLE + '">CAPA Plan: ' + safeString(plan.CompSuite__CAPA_Plan_Number__c) + '</div>';
        html += '</div>';
        html += '</div>';

        // Plan content block
        html += '<div style="width:100%; display:table; table-layout:fixed;">';
        html += '<div style="' + CONTENT_CELL_STYLE + '">';
        html += '<div style="padding:10px 6px 6px 10px;">';
        html += '<p style="margin:2px 0;"><b>CAPA Plan Name: </b>' + safeString(plan.Name) + '</p>';
        html += '<p style="margin:2px 0;"><b>CAPA Plan Number: </b>' + safeString(plan.CompSuite__CAPA_Plan_Number__c) + '</p>';
        html += '<p style="margin:2px 0;"><b>State: </b>' + safeString(planState) + '</p>';
        html += '</div>';
        html += '</div>';
        html += '</div>';

        // Related CAPAs
        if (relatedCAPAs.isEmpty()) {
            html += '<div style="padding:8px 10px; margin:6px 0 6px 30px; font-size:9pt; color:#666666; font-style:italic;">No CAPAs linked to this CAPA Plan</div>';
        } else {
            for (CompSuite__CAPA__c capa : relatedCAPAs) {
                html += buildCAPABlock(capa);
            }
        }

        html += '<br/>';
        return html;
    }

    private String buildCAPABlock(CompSuite__CAPA__c capa) {
        String stateName = (capa.CompSuite__State__r != null) ? capa.CompSuite__State__r.Name : '';
        String ownerName = (capa.Owner != null) ? capa.Owner.Name : '';

        String html = '';

        // Indented CAPA block using table spacer (30px indent)
        html += '<table style="width:100%; border-collapse:collapse; margin-top:6px;"><tr>';
        html += '<td style="width:30px; vertical-align:top;"></td>';
        html += '<td style="vertical-align:top;">';

        // CAPA sub-header bar
        html += '<div style="width:100%; display:table; table-layout:fixed;">';
        html += '<div style="border:1px solid black; margin-bottom:10px; page-break-inside:avoid;">';
        html += '<div style="' + SUBSECTION_HEADER_STYLE + '">CAPA: ' + safeString(capa.CAPA_Number__c) + '</div>';
        html += '</div>';
        html += '</div>';

        // CAPA content
        html += '<div style="width:100%; display:table; table-layout:fixed;">';
        html += '<div style="' + CONTENT_CELL_STYLE + '">';
        html += '<div style="padding:10px 6px 6px 10px;">';
        html += '<p style="margin:2px 0;"><b>CAPA Name: </b>' + safeString(capa.Name) + '</p>';
        html += '<p style="margin:2px 0;"><b>Owner Name: </b>' + safeString(ownerName) + '</p>';
        html += '<p style="margin:2px 0;"><b>Action Plan Description: </b>' + safeString(capa.CompSuite__Action_Plan_Description__c) + '</p>';
        html += '<p style="margin:2px 0;"><b>Planned Due Date: </b>' + formatDate(capa.CompSuite__Due_Date__c) + '</p>';
        html += '<p style="margin:2px 0;"><b>Completion Date: </b>' + formatDate(capa.Completion_Date__c) + '</p>';
        html += '<p style="margin:2px 0;"><b>State: </b>' + safeString(stateName) + '</p>';
        html += '</div>';
        html += '</div>';
        html += '</div>';

        html += '</td>';
        html += '</tr></table>';

        return html;
    }

    // ============================================
    // Query Methods
    // ============================================

    private List<CompSuite__CAPA_Plan__c> queryOpenCAPAPlans() {
        return [
            SELECT Id, Name, CompSuite__CAPA_Plan_Number__c,
                   CompSuite__State__r.Name
            FROM CompSuite__CAPA_Plan__c
            WHERE CompSuite__State__r.Name = null
               OR ((NOT CompSuite__State__r.Name LIKE '%Completed%')
                   AND (NOT CompSuite__State__r.Name LIKE '%Cancelled%'))
            WITH SECURITY_ENFORCED
            ORDER BY CompSuite__CAPA_Plan_Number__c ASC
        ];
    }

    private Map<Id, List<CompSuite__CAPA__c>> queryCAPAsByPlan(Set<Id> planIds) {
        Map<Id, List<CompSuite__CAPA__c>> planToCAPAs = new Map<Id, List<CompSuite__CAPA__c>>();

        if (planIds.isEmpty()) {
            return planToCAPAs;
        }

        List<CompSuite__CAPA__c> capaList = [
            SELECT Id, Name, CAPA_Number__c, CAPA_Plan__c,
                   Owner.Name,
                   CompSuite__Action_Plan_Description__c,
                   CompSuite__Due_Date__c,
                   Completion_Date__c,
                   CompSuite__State__r.Name
            FROM CompSuite__CAPA__c
            WHERE CAPA_Plan__c IN :planIds
            WITH SECURITY_ENFORCED
            ORDER BY CAPA_Number__c ASC
        ];

        for (CompSuite__CAPA__c capa : capaList) {
            if (!planToCAPAs.containsKey(capa.CAPA_Plan__c)) {
                planToCAPAs.put(capa.CAPA_Plan__c, new List<CompSuite__CAPA__c>());
            }
            planToCAPAs.get(capa.CAPA_Plan__c).add(capa);
        }

        return planToCAPAs;
    }

    // ============================================
    // Utility Methods
    // ============================================

    @TestVisible
    private String safeString(String value) {
        return String.isBlank(value) ? '' : value.escapeHtml4();
    }

    @TestVisible
    private String formatDate(Date d) {
        if (d == null) {
            return '';
        }
        DateTime dt = DateTime.newInstance(d.year(), d.month(), d.day());
        return dt.format('yyyy-MM-dd');
    }
}
