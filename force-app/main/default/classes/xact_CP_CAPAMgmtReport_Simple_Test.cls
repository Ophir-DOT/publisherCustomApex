@isTest
private class xact_CP_CAPAMgmtReport_Simple_Test {

    @isTest
    static void testGetJSON_returnsNull() {
        Test.startTest();
        xact_CP_CAPAMgmtReport_Simple gen = new xact_CP_CAPAMgmtReport_Simple();
        String json = gen.getJSON(null, null);
        Test.stopTest();

        System.assertEquals(null, json, 'getJSON should return null');
    }

    @isTest
    static void testGetHTML_noCAPAs() {
        Test.startTest();
        xact_CP_CAPAMgmtReport_Simple gen = new xact_CP_CAPAMgmtReport_Simple();
        String html = gen.getHTML(null, null);
        Test.stopTest();

        System.assert(html.contains('No open CAPAs found'), 'Should show empty state message');
        System.assert(html.contains('CAPA Management Report'), 'Should contain report title');
    }

    @isTest
    static void testGetHTML_withCAPAs() {
        CompSuite__CAPA__c capa = new CompSuite__CAPA__c();
        insert capa;

        Test.startTest();
        xact_CP_CAPAMgmtReport_Simple gen = new xact_CP_CAPAMgmtReport_Simple();
        String html = gen.getHTML(null, null);
        Test.stopTest();

        System.assert(html.contains('CAPA Management Report'), 'Should contain report title');
        System.assert(html.contains('CAPA:'), 'Should contain CAPA header');
    }

    @isTest
    static void testGetHTML_reportHeader() {
        Test.startTest();
        xact_CP_CAPAMgmtReport_Simple gen = new xact_CP_CAPAMgmtReport_Simple();
        String html = gen.getHTML(null, null);
        Test.stopTest();

        System.assert(html.contains('CAPA Management Report'), 'Should contain report title');
        System.assert(html.contains('Generated by'), 'Should contain generated by');
        System.assert(html.contains('Filtered By'), 'Should contain filter info');
    }

    @isTest
    static void testSafeString() {
        xact_CP_CAPAMgmtReport_Simple gen = new xact_CP_CAPAMgmtReport_Simple();

        System.assertEquals('', gen.safeString(null), 'Null should return empty');
        System.assertEquals('', gen.safeString(''), 'Empty should return empty');
        System.assertEquals('Test', gen.safeString('Test'), 'Normal string returned');
        System.assertEquals('&lt;b&gt;', gen.safeString('<b>'), 'HTML escaped');
    }

    @isTest
    static void testFormatDate() {
        xact_CP_CAPAMgmtReport_Simple gen = new xact_CP_CAPAMgmtReport_Simple();

        System.assertEquals('', gen.formatDate(null), 'Null date returns empty');
        String result = gen.formatDate(Date.newInstance(2026, 3, 15));
        System.assert(result.contains('2026'), 'Should contain year');
    }
}
